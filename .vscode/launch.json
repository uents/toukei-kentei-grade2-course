{
  "configurations": [
    {
      "name": "Python Debugger",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${fileDirname}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/",
      },
      "justMyCode": true
    }
  ]
}
